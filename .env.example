# Variables de entorno — Comercio de Narón
# Copia este archivo a ".env" para desarrollo local (NO se sube a Git).

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (obligatorio para el panel /admin y la sincronización de comercios)
# ─────────────────────────────────────────────────────────────────────────────

# URL del proyecto Supabase. Ejemplo: https://xxxx.supabase.co
SUPABASE_URL=

# Clave anónima (pública). Se usa en el navegador del panel y en lecturas
# públicas. Las políticas RLS la respaldan.
SUPABASE_ANON_KEY=

# Clave service_role (SECRETA). Se usa SOLO en el servidor para operaciones
# administrativas (CRUD del panel, sincronización, seed). NUNCA exponerla al
# navegador ni subirla al repo.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Integraciones existentes
# ─────────────────────────────────────────────────────────────────────────────

# Build Hook de Netlify. Al guardar un comercio/noticia/campaña en el panel,
# el servidor hace POST a esta URL para disparar un deploy automático que
# regenera la web pública (sync:comercios + build). Déjala vacía para
# desactivar el auto-deploy: el guardado en Supabase funciona igual y podrás
# desplegar manualmente. Cómo crearlo: ver docs/ADMIN.md.
NETLIFY_BUILD_HOOK_URL=

# URL del webhook de n8n para los formularios públicos (alta de socio,
# contacto, newsletter). Déjala vacía para mantener el "modo demo": los
# formularios muestran confirmación pero no envían datos a ningún servidor.
PUBLIC_N8N_WEBHOOK=
