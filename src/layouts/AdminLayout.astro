---
import '../styles/global.css';
import Sidebar from '../components/admin/Sidebar.astro';
import Topbar from '../components/admin/Topbar.astro';
import Flash from '../components/admin/Flash.astro';
import type { SessionUser } from '../lib/supabase/types';

interface Props {
  title: string;
  description?: string;
  current: string;
  user: SessionUser;
}

const { title, description, current, user } = Astro.props;
const flash = Astro.url.searchParams.get('flash');
const flashType = (Astro.url.searchParams.get('flashType') as 'success' | 'error' | 'info' | null) ?? 'success';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Panel · Comercio de Narón</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:wght@500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <Sidebar user={user} current={current} />
    <div class="lg:pl-64 min-h-screen flex flex-col">
      <Topbar title={title} description={description} user={user}>
        <slot name="topbar-actions" />
      </Topbar>
      <main class="flex-1 px-4 py-6 lg:px-8 lg:py-8">
        {flash && (
          <div class="mb-6 max-w-3xl">
            <Flash type={flashType} message={flash} />
          </div>
        )}
        <slot />
      </main>
      <footer class="border-t border-slate-200 px-4 py-4 text-center text-xs text-slate-400 lg:px-8">
        Panel admin · Asociación de Comerciantes de Narón
      </footer>
    </div>
  </body>
</html>
