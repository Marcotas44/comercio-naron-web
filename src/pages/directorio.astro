---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import Icon from '../components/Icon.astro';
import { comercios, categorias, zonas, soloDigitos } from '../data/comercios';
import dims from '../data/img-dims.json';
---
<Layout title="Directorio de comercios | Comercio de Narón"
        description={`Encuentra entre ${comercios.length} comercios locales de Narón. Filtra por categoría y zona: alimentación, moda, hostelería, servicios y más.`}>

  <PageHero eyebrow="Directorio"
            title="Encuentra tu comercio en Narón"
            subtitle={`${comercios.length} comercios locales asociados en ${categorias.length} categorías. Filtra por lo que buscas y por tu zona.`} />

  <!-- BUSCADOR + FILTROS -->
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="rounded-2xl border border-brand-100 bg-white p-5 shadow-soft">
      <div class="grid gap-3 md:grid-cols-3">
        <div class="relative md:col-span-1">
          <Icon name="search" class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-ink/40" />
          <input id="buscar" type="search" placeholder="Buscar por nombre…"
                 class="w-full rounded-xl border border-brand-100 py-3 pl-12 pr-4 outline-none focus:border-brand" />
        </div>
        <select id="filtro-cat" class="rounded-xl border border-brand-100 px-4 py-3 outline-none focus:border-brand">
          <option value="">Todas las categorías</option>
          {categorias.map((c) => <option value={c}>{c}</option>)}
        </select>
        <select id="filtro-zona" class="rounded-xl border border-brand-100 px-4 py-3 outline-none focus:border-brand">
          <option value="">Todas las zonas</option>
          {zonas.map((z) => <option value={z}>{z}</option>)}
        </select>
      </div>
    </div>

    <p id="contador" class="mt-5 text-sm text-ink/60">{comercios.length} comercios</p>

    <!-- GRID -->
    <div id="grid" class="mt-4 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {comercios.map((c) => {
        const tel = soloDigitos(c.telefono);
        return (
          <article class="card flex flex-col overflow-hidden rounded-2xl border border-brand-100 bg-white shadow-soft transition hover:-translate-y-1"
                   data-cat={c.categoria} data-zona={c.zona} data-name={c.nombre.toLowerCase()}>
            <div class="relative h-40 overflow-hidden">
              {c.imagen ? (
                <img src={c.imagen} alt={c.nombre} width={dims[c.imagen]?.w} height={dims[c.imagen]?.h} loading="lazy" class="h-full w-full object-cover" />
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-brand-50">
                  <Icon name="store" class="h-10 w-10 text-brand/40" />
                </div>
              )}
              {c.categoria && <span class="absolute left-3 top-3 rounded-full bg-brand px-3 py-1 text-xs font-bold text-white">{c.categoria}</span>}
            </div>
            <div class="flex flex-1 flex-col p-5">
              <h3 class="font-display text-lg font-bold leading-snug">{c.nombre}</h3>
              <p class="mt-1.5 flex items-start gap-1.5 text-xs font-medium text-ink/55">
                <Icon name="mappin" class="mt-0.5 h-3.5 w-3.5 shrink-0" />
                <span>{c.direccion || 'Dirección no disponible'}{c.zona ? ` · ${c.zona}` : ''}</span>
              </p>

              <div class="mt-4 flex flex-1 flex-wrap items-end gap-2">
                {tel && (
                  <>
                    <a href={`https://wa.me/34${tel}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1.5 text-sm font-semibold text-brand hover:bg-brand-100"><Icon name="whatsapp" class="h-4 w-4" /> WhatsApp</a>
                    <a href={`tel:+34${tel}`} class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1.5 text-sm font-semibold text-brand hover:bg-brand-100"><Icon name="phone" class="h-4 w-4" /> Llamar</a>
                  </>
                )}
                {c.email && <a href={`mailto:${c.email}`} class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1.5 text-sm font-semibold text-brand hover:bg-brand-100"><Icon name="mail" class="h-4 w-4" /> Email</a>}
                {c.web && <a href={c.web} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1.5 text-sm font-semibold text-brand hover:bg-brand-100"><Icon name="arrow" class="h-4 w-4" /> Web</a>}
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <p id="vacio" class="mt-10 hidden text-center text-ink/60">No hay comercios que coincidan con tu búsqueda.</p>
  </section>

  <CTA title="¿Tu comercio aún no está en el directorio?"
       text="Date de alta en la asociación y aparece ante miles de vecinos de Narón."
       ctaLabel="Hazte socio" ctaHref="/hazte-socio" />
</Layout>

<script>
  const buscar = document.getElementById('buscar');
  const cat = document.getElementById('filtro-cat');
  const zona = document.getElementById('filtro-zona');
  const cards = Array.from(document.querySelectorAll('.card'));
  const contador = document.getElementById('contador');
  const vacio = document.getElementById('vacio');

  function aplicar() {
    const q = (buscar.value || '').toLowerCase().trim();
    const c = cat.value;
    const z = zona.value;
    let visibles = 0;
    cards.forEach((card) => {
      const show = (!c || card.dataset.cat === c) && (!z || card.dataset.zona === z) && (!q || card.dataset.name.includes(q));
      card.classList.toggle('hidden', !show);
      if (show) visibles++;
    });
    contador.textContent = `${visibles} comercio${visibles === 1 ? '' : 's'}`;
    vacio.classList.toggle('hidden', visibles !== 0);
  }

  buscar.addEventListener('input', aplicar);
  cat.addEventListener('change', aplicar);
  zona.addEventListener('change', aplicar);
</script>
