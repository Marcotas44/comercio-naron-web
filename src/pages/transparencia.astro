---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import Icon from '../components/Icon.astro';
import { totalComercios } from '../data/comercios';
import { ENTIDAD } from '../data/asociacion';

const objetivos = [
  { icon: 'megaphone', t: 'Dar visibilidad', d: 'Promocionar de forma conjunta a los comercios asociados y atraer clientes al comercio de proximidad.' },
  { icon: 'users', t: 'Representar', d: 'Ser la voz de los comerciantes ante el Ayuntamiento y las administraciones.' },
  { icon: 'gift', t: 'Dinamizar', d: 'Organizar campañas, sorteos y eventos que llenen de vida las calles de Narón.' },
  { icon: 'shield', t: 'Acompañar', d: 'Ofrecer formación, asesoramiento y apoyo a los comercios asociados.' },
];

const junta = [
  { cargo: 'Presidencia', nombre: '[NOMBRE]' },
  { cargo: 'Vicepresidencia', nombre: '[NOMBRE]' },
  { cargo: 'Secretaría', nombre: '[NOMBRE]' },
  { cargo: 'Tesorería', nombre: '[NOMBRE]' },
];
---
<Layout title="Transparencia | Comercio de Narón"
        description="Quiénes somos, qué hacemos por el comercio local de Narón, cómo asociarse y nuestro compromiso con los comercios y la protección de datos.">
  <PageHero eyebrow="Quiénes somos" title="Transparencia y confianza"
            subtitle="Una asociación al servicio del comercio local de Narón, con las cuentas y los objetivos claros." />

  <!-- Quiénes somos -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">La asociación</p>
      <h2 class="rule-accent mt-2 font-display text-3xl font-extrabold">{totalComercios} comercios que reman juntos</h2>
      <p class="mt-5 text-ink/75">Somos una asociación sin ánimo de lucro que agrupa a {totalComercios} comercios
      locales de Narón. Trabajamos para que comprar cerca siga mereciendo la pena: defendemos el comercio de
      proximidad, lo promocionamos y le damos una voz común ante las instituciones.</p>
    </div>
  </section>

  <!-- Objetivos -->
  <section class="bg-cream bg-grid">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="rule-accent font-display text-2xl font-extrabold md:text-3xl">Qué hacemos por los comercios</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {objetivos.map((o) => (
          <div class="rounded-2xl border border-brand-100 bg-white p-6 shadow-soft">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand"><Icon name={o.icon} /></div>
            <h3 class="mt-4 font-bold">{o.t}</h3>
            <p class="mt-1 text-sm text-ink/70">{o.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cómo asociarse + cuota -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <h2 class="rule-accent font-display text-2xl font-extrabold md:text-3xl">Cómo hacerse socio</h2>
        <ol class="mt-6 space-y-4">
          <li class="flex gap-3"><span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand font-bold text-white">1</span><span class="text-ink/75">Rellenas el formulario de alta en la web.</span></li>
          <li class="flex gap-3"><span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand font-bold text-white">2</span><span class="text-ink/75">Te contactamos para confirmar los datos de tu comercio.</span></li>
          <li class="flex gap-3"><span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand font-bold text-white">3</span><span class="text-ink/75">Te incorporas al directorio y a todas las campañas.</span></li>
        </ol>
      </div>
      <div class="rounded-3xl bg-brand p-8 text-white shadow-soft md:p-10">
        <p class="text-sm font-semibold uppercase tracking-wide text-accent-soft">Cuota transparente</p>
        <div class="mt-2 font-display text-6xl font-black text-accent-soft">6€<span class="text-2xl font-bold text-white/70">/mes</span></div>
        <p class="mt-3 text-white/85">Sin permanencia. La cuota financia las campañas, los materiales y la
        representación de todos los comercios asociados.</p>
        <a href="/hazte-socio" class="mt-6 inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 font-bold text-brand-dark transition hover:bg-accent-soft">Hazte socio <Icon name="arrow" class="h-5 w-5" /></a>
      </div>
    </div>
  </section>

  <!-- Junta directiva -->
  <section class="bg-cream bg-grid">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="rule-accent font-display text-2xl font-extrabold md:text-3xl">Junta directiva</h2>
      <p class="mt-3 text-ink/70">La asociación se rige por una junta directiva elegida por sus socios.</p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {junta.map((j) => (
          <div class="rounded-2xl border border-brand-100 bg-white p-6 text-center shadow-soft">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-50 text-brand"><Icon name="users" /></div>
            <h3 class="mt-4 font-bold">{j.cargo}</h3>
            <p class="mt-1 text-sm"><span class="ph rounded bg-brand-50 px-1.5 py-0.5 font-semibold text-brand-dark">{j.nombre}</span></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Compromisos + contacto -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-2xl border border-brand-100 bg-white p-7 shadow-soft">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand"><Icon name="heart" /></div>
        <h3 class="mt-4 font-display text-xl font-bold">Compromiso con el comercio local</h3>
        <p class="mt-2 text-ink/75">Defendemos un modelo de ciudad con comercio de proximidad, empleo local y
        calles vivas. Cada euro que se queda en el barrio nos hace más fuertes a todos.</p>
      </div>
      <div class="rounded-2xl border border-brand-100 bg-white p-7 shadow-soft">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand"><Icon name="shield" /></div>
        <h3 class="mt-4 font-display text-xl font-bold">Compromiso con tus datos</h3>
        <p class="mt-2 text-ink/75">Tratamos los datos de socios y usuarios con responsabilidad y conforme al
        RGPD. Consulta la <a href="/politica-privacidad" class="font-semibold text-brand underline">política de
        privacidad</a> y la página de <a href="/proteccion-datos" class="font-semibold text-brand underline">protección de datos</a>.</p>
      </div>
    </div>

    <div class="mt-8 rounded-2xl bg-brand-50 p-6">
      <h3 class="font-bold text-brand-dark">Contacto</h3>
      <p class="mt-2 text-sm text-ink/75">Teléfono: {ENTIDAD.telefono} · Email: <span class="ph rounded bg-white px-1.5 py-0.5 font-semibold text-brand-dark">{ENTIDAD.emailLegal}</span> · Narón, A Coruña (Galicia)</p>
    </div>
  </section>

  <CTA title="Forma parte del comercio de Narón"
       text="Súmate a la asociación desde 6€/mes y hagamos crecer juntos el comercio local."
       ctaLabel="Hazte socio" ctaHref="/hazte-socio" />
</Layout>
