---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/Icon.astro';
import { supabaseAdmin } from '../../../lib/supabase/admin';

const user = Astro.locals.user!;
const sb = supabaseAdmin();
const q = (Astro.url.searchParams.get('q') ?? '').trim();
const estado = Astro.url.searchParams.get('estado') ?? '';

let query = sb.from('noticias').select('id, titulo, slug, publicado, fecha_publicacion, autor, imagen, updated_at').order('created_at', { ascending: false });
if (q) query = query.ilike('titulo', `%${q}%`);
if (estado === 'publicado') query = query.eq('publicado', true);
else if (estado === 'borrador') query = query.eq('publicado', false);

const { data } = await query;
const noticias = (data ?? []) as Array<any>;

function fmtDate(d: string | null) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
}
---
<AdminLayout title="Noticias" description={`${noticias.length} entradas`} current="noticias" user={user}>
  <a slot="topbar-actions" href="/admin/noticias/nueva" class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-brand)] px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[var(--color-brand-dark)]">
    <Icon name="plus" class="h-4 w-4" /> Nueva noticia
  </a>

  <form method="GET" class="mb-5 grid gap-3 rounded-xl border border-slate-200 bg-white p-4 md:grid-cols-[1fr_auto_auto]">
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-3 grid place-items-center text-slate-400"><Icon name="search" class="h-4 w-4" /></span>
      <input type="search" name="q" value={q} placeholder="Buscar por título…" class="w-full rounded-lg border border-slate-300 bg-white pl-9 pr-3 py-2 text-sm" />
    </div>
    <select name="estado" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm">
      <option value="">Todas</option>
      <option value="publicado" selected={estado === 'publicado'}>Publicadas</option>
      <option value="borrador" selected={estado === 'borrador'}>Borradores</option>
    </select>
    <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Aplicar</button>
  </form>

  {noticias.length === 0 ? (
    <div class="rounded-xl border border-dashed border-slate-300 bg-white p-10 text-center">
      <p class="text-sm text-slate-500">Aún no hay noticias.</p>
      <a href="/admin/noticias/nueva" class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-brand)] px-3 py-2 text-sm font-semibold text-white hover:bg-[var(--color-brand-dark)]">
        <Icon name="plus" class="h-4 w-4" /> Crear la primera noticia
      </a>
    </div>
  ) : (
    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3 font-semibold">Noticia</th>
            <th class="px-4 py-3 font-semibold">Estado</th>
            <th class="px-4 py-3 font-semibold">Publicación</th>
            <th class="px-4 py-3 font-semibold">Autor</th>
            <th class="px-4 py-3 font-semibold text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {noticias.map(n => (
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-14 shrink-0 overflow-hidden rounded-md bg-slate-100">
                    {n.imagen ? <img src={n.imagen} alt="" class="h-full w-full object-cover" loading="lazy" /> : <span class="grid h-full w-full place-items-center text-slate-400"><Icon name="newspaper" class="h-4 w-4" /></span>}
                  </div>
                  <div>
                    <div class="font-medium text-slate-900">{n.titulo}</div>
                    <div class="text-xs text-slate-500">/{n.slug}</div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class:list={['rounded-full px-2 py-0.5 text-[11px] font-medium', n.publicado ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-slate-100 text-slate-600 border border-slate-200']}>
                  {n.publicado ? 'Publicada' : 'Borrador'}
                </span>
              </td>
              <td class="px-4 py-3 text-xs text-slate-500">{fmtDate(n.fecha_publicacion)}</td>
              <td class="px-4 py-3 text-slate-600">{n.autor ?? '—'}</td>
              <td class="px-4 py-3 text-right">
                <a href={`/admin/noticias/${n.id}`} class="text-sm font-medium text-[var(--color-brand)] hover:underline">Editar</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
