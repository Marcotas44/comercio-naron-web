---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/Icon.astro';
import { supabaseAdmin } from '../../../lib/supabase/admin';

const user = Astro.locals.user!;
const sb = supabaseAdmin();
const q = (Astro.url.searchParams.get('q') ?? '').trim();
const estado = (Astro.url.searchParams.get('estado') ?? '').trim();

let query = sb.from('solicitudes_socio').select('id, comercio_nombre, contacto_nombre, email, telefono, estado, created_at').order('created_at', { ascending: false });
if (q) query = query.or(`comercio_nombre.ilike.%${q}%,contacto_nombre.ilike.%${q}%,email.ilike.%${q}%`);
if (estado === 'pendiente' || estado === 'aceptado' || estado === 'rechazado') query = query.eq('estado', estado);

const { data } = await query;
const solicitudes = (data ?? []) as Array<any>;

const counts = await Promise.all([
  sb.from('solicitudes_socio').select('id', { count: 'exact', head: true }).eq('estado', 'pendiente'),
  sb.from('solicitudes_socio').select('id', { count: 'exact', head: true }).eq('estado', 'aceptado'),
  sb.from('solicitudes_socio').select('id', { count: 'exact', head: true }).eq('estado', 'rechazado'),
]);
const totales = {
  pendiente: counts[0].count ?? 0,
  aceptado:  counts[1].count ?? 0,
  rechazado: counts[2].count ?? 0,
};

function fmtDate(d: string) {
  return new Date(d).toLocaleString('es-ES', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const estadoBadge: Record<string, string> = {
  pendiente: 'bg-amber-50 text-amber-700 border border-amber-200',
  aceptado:  'bg-emerald-50 text-emerald-700 border border-emerald-200',
  rechazado: 'bg-rose-50 text-rose-700 border border-rose-200',
};
---
<AdminLayout title="Solicitudes de socio" description={`${solicitudes.length} solicitudes ${estado ? `· ${estado}` : 'mostradas'}`} current="solicitudes" user={user}>
  <div class="mb-5 grid gap-3 sm:grid-cols-3">
    <a href="/admin/solicitudes?estado=pendiente" class:list={['rounded-xl border bg-white p-4 transition hover:shadow', estado === 'pendiente' ? 'border-amber-300 ring-2 ring-amber-200' : 'border-slate-200']}>
      <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Pendientes</p>
      <p class="mt-1 font-display text-2xl font-semibold text-slate-900">{totales.pendiente}</p>
    </a>
    <a href="/admin/solicitudes?estado=aceptado" class:list={['rounded-xl border bg-white p-4 transition hover:shadow', estado === 'aceptado' ? 'border-emerald-300 ring-2 ring-emerald-200' : 'border-slate-200']}>
      <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Aceptadas</p>
      <p class="mt-1 font-display text-2xl font-semibold text-slate-900">{totales.aceptado}</p>
    </a>
    <a href="/admin/solicitudes?estado=rechazado" class:list={['rounded-xl border bg-white p-4 transition hover:shadow', estado === 'rechazado' ? 'border-rose-300 ring-2 ring-rose-200' : 'border-slate-200']}>
      <p class="text-xs font-semibold uppercase tracking-wide text-rose-700">Rechazadas</p>
      <p class="mt-1 font-display text-2xl font-semibold text-slate-900">{totales.rechazado}</p>
    </a>
  </div>

  <form method="GET" class="mb-5 grid gap-3 rounded-xl border border-slate-200 bg-white p-4 md:grid-cols-[1fr_auto_auto_auto]">
    <div class="relative">
      <span class="pointer-events-none absolute inset-y-0 left-3 grid place-items-center text-slate-400"><Icon name="search" class="h-4 w-4" /></span>
      <input type="search" name="q" value={q} placeholder="Buscar por comercio, contacto o email…" class="w-full rounded-lg border border-slate-300 bg-white pl-9 pr-3 py-2 text-sm" />
    </div>
    <select name="estado" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm">
      <option value="">Todos los estados</option>
      <option value="pendiente" selected={estado === 'pendiente'}>Pendiente</option>
      <option value="aceptado" selected={estado === 'aceptado'}>Aceptado</option>
      <option value="rechazado" selected={estado === 'rechazado'}>Rechazado</option>
    </select>
    <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Filtrar</button>
    <a href="/admin/solicitudes" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">Limpiar</a>
  </form>

  {solicitudes.length === 0 ? (
    <div class="rounded-xl border border-dashed border-slate-300 bg-white p-10 text-center">
      <p class="text-sm text-slate-500">No hay solicitudes con esos filtros.</p>
    </div>
  ) : (
    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3 font-semibold">Comercio</th>
            <th class="px-4 py-3 font-semibold">Contacto</th>
            <th class="px-4 py-3 font-semibold">Recibida</th>
            <th class="px-4 py-3 font-semibold">Estado</th>
            <th class="px-4 py-3 font-semibold text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {solicitudes.map(s => (
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3">
                <div class="font-medium text-slate-900">{s.comercio_nombre}</div>
              </td>
              <td class="px-4 py-3 text-slate-600">
                <div>{s.contacto_nombre}</div>
                <div class="text-xs text-slate-500">{s.email}{s.telefono ? ` · ${s.telefono}` : ''}</div>
              </td>
              <td class="px-4 py-3 text-xs text-slate-500">{fmtDate(s.created_at)}</td>
              <td class="px-4 py-3">
                <span class:list={['rounded-full px-2 py-0.5 text-[11px] font-medium', estadoBadge[s.estado]]}>{s.estado}</span>
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/admin/solicitudes/${s.id}`} class="text-sm font-medium text-[var(--color-brand)] hover:underline">Abrir</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
