---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/Icon.astro';
import { supabaseAdmin } from '../../../lib/supabase/admin';
import type { SolicitudSocio } from '../../../lib/supabase/types';

const user = Astro.locals.user!;
const { id } = Astro.params;
const sb = supabaseAdmin();

const { data, error } = await sb.from('solicitudes_socio').select('*').eq('id', id!).maybeSingle();
if (error || !data) {
  return Astro.redirect('/admin/solicitudes?flash=' + encodeURIComponent('Solicitud no encontrada.') + '&flashType=error');
}
const solicitud = data as unknown as SolicitudSocio;

const comercioNombre = solicitud.comercio ?? solicitud.comercio_nombre ?? '—';
const contactoNombre = solicitud.nombre ?? solicitud.contacto_nombre ?? '—';

function fmtDate(d: string) {
  return new Date(d).toLocaleString('es-ES', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

const estadoBadge: Record<string, string> = {
  pendiente: 'bg-amber-50 text-amber-700 border border-amber-200',
  contactado: 'bg-sky-50 text-sky-700 border border-sky-200',
  aceptado:  'bg-emerald-50 text-emerald-700 border border-emerald-200',
  rechazado: 'bg-rose-50 text-rose-700 border border-rose-200',
};
---
<AdminLayout title={comercioNombre} description={`Solicitud recibida el ${fmtDate(solicitud.created_at)}`} current="solicitudes" user={user}>
  <div class="grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-6">
      <section class="rounded-xl border border-slate-200 bg-white p-6">
        <h2 class="font-display text-lg font-semibold text-slate-900">Datos del comercio</h2>
        <dl class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 text-sm">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Comercio</dt>
            <dd class="mt-1 font-medium text-slate-900">{comercioNombre}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Contacto</dt>
            <dd class="mt-1 font-medium text-slate-900">{contactoNombre}</dd>
          </div>
          {solicitud.categoria && (
            <div>
              <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Categoría</dt>
              <dd class="mt-1 text-slate-900">{solicitud.categoria}</dd>
            </div>
          )}
          {solicitud.direccion && (
            <div>
              <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Dirección</dt>
              <dd class="mt-1 text-slate-900">{solicitud.direccion}</dd>
            </div>
          )}
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Email</dt>
            <dd class="mt-1">{solicitud.email ? <a href={`mailto:${solicitud.email}`} class="text-[var(--color-brand)] hover:underline">{solicitud.email}</a> : <span class="text-slate-400">—</span>}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">Teléfono</dt>
            <dd class="mt-1">{solicitud.telefono ? <a href={`tel:${solicitud.telefono}`} class="text-[var(--color-brand)] hover:underline">{solicitud.telefono}</a> : <span class="text-slate-400">—</span>}</dd>
          </div>
        </dl>
        {solicitud.mensaje && (
          <div class="mt-6">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Mensaje</p>
            <p class="mt-2 whitespace-pre-line rounded-lg bg-slate-50 p-4 text-sm text-slate-700">{solicitud.mensaje}</p>
          </div>
        )}
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-6">
        <h2 class="font-display text-lg font-semibold text-slate-900">Notas internas</h2>
        <p class="mt-1 text-xs text-slate-500">Visible solo para el equipo gestor.</p>
        <form method="POST" action={`/api/admin/solicitudes/${solicitud.id}`} class="mt-4 space-y-3">
          <input type="hidden" name="_action" value="notas" />
          <textarea name="notas_internas" rows={5} class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]/20" placeholder="Próximos pasos, llamadas, observaciones…">{solicitud.notas_internas ?? ''}</textarea>
          <div class="flex justify-end">
            <button type="submit" class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700">Guardar notas</button>
          </div>
        </form>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="rounded-xl border border-slate-200 bg-white p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Estado actual</p>
        <p class="mt-2"><span class:list={['rounded-full px-3 py-1 text-xs font-medium', estadoBadge[solicitud.estado]]}>{solicitud.estado}</span></p>

        <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-slate-500">Cambiar estado</p>
        <div class="mt-3 flex flex-col gap-2">
          <form method="POST" action={`/api/admin/solicitudes/${solicitud.id}`}>
            <input type="hidden" name="_action" value="estado" />
            <input type="hidden" name="estado" value="contactado" />
            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-lg bg-sky-600 px-3 py-2 text-sm font-semibold text-white hover:bg-sky-700"><Icon name="phone" class="h-4 w-4" /> Marcar como contactado</button>
          </form>
          <form method="POST" action={`/api/admin/solicitudes/${solicitud.id}`}>
            <input type="hidden" name="_action" value="estado" />
            <input type="hidden" name="estado" value="aceptado" />
            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-lg bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700"><Icon name="check" class="h-4 w-4" /> Aceptar</button>
          </form>
          <form method="POST" action={`/api/admin/solicitudes/${solicitud.id}`}>
            <input type="hidden" name="_action" value="estado" />
            <input type="hidden" name="estado" value="rechazado" />
            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-lg bg-rose-600 px-3 py-2 text-sm font-semibold text-white hover:bg-rose-700"><Icon name="x" class="h-4 w-4" /> Rechazar</button>
          </form>
          <form method="POST" action={`/api/admin/solicitudes/${solicitud.id}`}>
            <input type="hidden" name="_action" value="estado" />
            <input type="hidden" name="estado" value="pendiente" />
            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Marcar como pendiente</button>
          </form>
        </div>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Cronología</p>
        <p class="mt-2 text-sm text-slate-700">Recibida: <span class="font-medium">{fmtDate(solicitud.created_at)}</span></p>
        <p class="mt-1 text-sm text-slate-700">Actualizada: <span class="font-medium">{fmtDate(solicitud.updated_at)}</span></p>
      </section>

      <form method="POST" action={`/api/admin/solicitudes/${solicitud.id}/delete`} class="rounded-xl border border-rose-200 bg-rose-50/50 p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-rose-700">Eliminar</p>
        <p class="mt-1 text-xs text-rose-700/80">Permanente. Solo si la solicitud es spam o un error.</p>
        <button type="submit" onclick="return confirm('¿Eliminar esta solicitud? Esta acción no se puede deshacer.')" class="mt-3 w-full rounded-lg border border-rose-300 bg-white px-3 py-2 text-sm font-medium text-rose-700 hover:bg-rose-100">Eliminar definitivamente</button>
      </form>
    </aside>
  </div>
</AdminLayout>
