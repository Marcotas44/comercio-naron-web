---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import FormField from '../../components/admin/FormField.astro';
import Icon from '../../components/Icon.astro';
import { supabaseAdmin } from '../../lib/supabase/admin';
import type { Profile, UserRole } from '../../lib/supabase/types';

const user = Astro.locals.user!;
const sb = supabaseAdmin();

// Lista de usuarios del panel (solo super_admin)
let usuarios: Profile[] = [];
if (user.role === 'super_admin') {
  const { data } = await sb.from('profiles').select('id, email, nombre, role, created_at, updated_at').order('created_at', { ascending: true });
  usuarios = (data ?? []) as unknown as Profile[];
}

const roleLabel: Record<UserRole, string> = {
  super_admin: 'Super Admin',
  admin_asociacion: 'Administrador Asociación',
  editor: 'Editor',
};
const roleClasses: Record<UserRole, string> = {
  super_admin: 'bg-[var(--color-brand)] text-white',
  admin_asociacion: 'bg-amber-100 text-amber-800',
  editor: 'bg-slate-100 text-slate-700',
};
---
<AdminLayout title="Configuración" description="Tu perfil y, si tienes permisos, los usuarios del panel" current="configuracion" user={user}>
  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-xl border border-slate-200 bg-white p-6">
      <h2 class="font-display text-lg font-semibold text-slate-900">Tu perfil</h2>
      <p class="mt-1 text-xs text-slate-500">Estos datos se muestran en la cabecera del panel.</p>
      <form method="POST" action="/api/admin/perfil" class="mt-6 space-y-4">
        <FormField label="Nombre visible" name="nombre" value={user.nombre ?? ''} placeholder="Ej. Choly Pérez" />
        <FormField label="Email" name="email" value={user.email} hint="Para cambiar el email, contacta con el super admin." />
        <div class="flex justify-end">
          <button type="submit" class="rounded-lg bg-[var(--color-brand)] px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[var(--color-brand-dark)]">Guardar perfil</button>
        </div>
      </form>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white p-6">
      <h2 class="font-display text-lg font-semibold text-slate-900">Cambiar contraseña</h2>
      <p class="mt-1 text-xs text-slate-500">Mínimo 8 caracteres.</p>
      <form method="POST" action="/api/admin/password" class="mt-6 space-y-4">
        <FormField label="Nueva contraseña" name="password" type="password" required hint="No la compartas con nadie." />
        <FormField label="Repite la contraseña" name="password2" type="password" required />
        <div class="flex justify-end">
          <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700">Cambiar contraseña</button>
        </div>
      </form>
    </section>
  </div>

  {user.role === 'super_admin' && (
    <section class="mt-8 rounded-xl border border-slate-200 bg-white">
      <header class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 px-5 py-4">
        <div>
          <h2 class="font-display text-lg font-semibold text-slate-900">Usuarios del panel</h2>
          <p class="text-xs text-slate-500">Crea cuentas y asigna roles. Solo el Super Admin puede gestionarlas.</p>
        </div>
        <button type="button" class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-brand)] px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[var(--color-brand-dark)]" data-open-user>
          <Icon name="plus" class="h-4 w-4" /> Invitar usuario
        </button>
      </header>

      <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3 font-semibold">Usuario</th>
            <th class="px-5 py-3 font-semibold">Rol</th>
            <th class="px-5 py-3 font-semibold">Creado</th>
            <th class="px-5 py-3 font-semibold text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {usuarios.map(u => (
            <tr>
              <td class="px-5 py-3">
                <div class="font-medium text-slate-900">{u.nombre ?? u.email.split('@')[0]}</div>
                <div class="text-xs text-slate-500">{u.email}</div>
              </td>
              <td class="px-5 py-3">
                <form method="POST" action="/api/admin/users" class="flex items-center gap-2">
                  <input type="hidden" name="_action" value="role" />
                  <input type="hidden" name="id" value={u.id} />
                  <select name="role" class="rounded-md border border-slate-300 bg-white px-2 py-1 text-xs">
                    <option value="editor" selected={u.role === 'editor'}>Editor</option>
                    <option value="admin_asociacion" selected={u.role === 'admin_asociacion'}>Administrador</option>
                    <option value="super_admin" selected={u.role === 'super_admin'}>Super Admin</option>
                  </select>
                  <button type="submit" class="rounded-md bg-slate-900 px-2 py-1 text-xs font-medium text-white hover:bg-slate-700">Guardar</button>
                </form>
              </td>
              <td class="px-5 py-3 text-xs text-slate-500">{new Date(u.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}</td>
              <td class="px-5 py-3 text-right">
                {u.id !== user.id ? (
                  <form method="POST" action="/api/admin/users" class="inline" onsubmit="return confirm('¿Eliminar este usuario? Perderá el acceso al panel.')">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={u.id} />
                    <button type="submit" class="text-xs font-medium text-rose-600 hover:underline">Eliminar</button>
                  </form>
                ) : (
                  <span class="text-xs text-slate-400">Tú</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      <dialog id="user-dialog" class="rounded-2xl border border-slate-200 p-0 backdrop:bg-black/40">
        <form method="POST" action="/api/admin/users" class="w-[28rem] max-w-[95vw] p-6">
          <input type="hidden" name="_action" value="create" />
          <h3 class="font-display text-lg font-semibold text-slate-900">Invitar usuario</h3>
          <p class="mt-1 text-xs text-slate-500">Se creará una cuenta con la contraseña indicada. El usuario podrá entrar inmediatamente.</p>
          <div class="mt-5 space-y-4">
            <FormField label="Nombre" name="nombre" required placeholder="Ej. María Pérez" />
            <FormField label="Email" name="email" type="email" required autocomplete="email" />
            <FormField label="Contraseña inicial" name="password" type="password" required hint="Mínimo 8 caracteres. El usuario podrá cambiarla en Configuración." />
            <FormField label="Rol" name="role" options={[
              { value: 'editor', label: 'Editor' },
              { value: 'admin_asociacion', label: 'Administrador Asociación' },
              { value: 'super_admin', label: 'Super Admin' },
            ]} value="editor" required />
          </div>
          <div class="mt-6 flex justify-end gap-3">
            <button type="button" class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" data-close-user>Cancelar</button>
            <button type="submit" class="rounded-lg bg-[var(--color-brand)] px-4 py-2 text-sm font-semibold text-white hover:bg-[var(--color-brand-dark)]">Crear usuario</button>
          </div>
        </form>
      </dialog>

      <script is:inline>
        document.addEventListener('click', (e) => {
          const t = e.target;
          if (!(t instanceof Element)) return;
          if (t.closest('[data-open-user]')) document.getElementById('user-dialog')?.showModal();
          if (t.closest('[data-close-user]')) document.getElementById('user-dialog')?.close();
        });
      </script>
    </section>
  )}
</AdminLayout>
