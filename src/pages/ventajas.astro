---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
import Icon from '../components/Icon.astro';

const ventajas = [
  { icon: 'megaphone', title: 'Más visibilidad', text: 'Ficha en el directorio online y presencia en todas las campañas y redes de la asociación.' },
  { icon: 'gift', title: 'Campañas conjuntas', text: 'Sorteos, eventos y promociones de calle que ningún comercio podría costear en solitario.' },
  { icon: 'users', title: 'Representación', text: 'Una voz fuerte ante el Ayuntamiento y las administraciones para defender tus intereses.' },
  { icon: 'shield', title: 'Respaldo y formación', text: 'Asesoramiento, formación y el apoyo de una asociación consolidada en Narón.' },
  { icon: 'sparkles', title: 'Identidad común', text: 'Material e imagen corporativa que refuerzan la marca “Comercio de Narón”.' },
  { icon: 'heart', title: 'Comunidad', text: 'Más de 90 comercios que comparten ideas, proveedores y se ayudan entre sí.' },
];

const solo = [
  'Compites en solitario contra grandes superficies',
  'Pagas tú toda la publicidad de tu tienda',
  'Sin voz ante el Ayuntamiento',
  'Sin presencia en campañas ni sorteos',
];
const asociado = [
  'Formas parte de una marca de +90 comercios',
  'Marketing y campañas compartidas',
  'Representación institucional colectiva',
  'Apareces en el directorio y todos los eventos',
];

const incluye = [
  'Ficha en el directorio online de comercios',
  'Participación en sorteos y campañas conjuntas',
  'Material e identidad corporativa de la asociación',
  'Representación ante el Ayuntamiento y administraciones',
  'Formación y asesoramiento para tu negocio',
  'Una comunidad de +90 comercios que reman contigo',
];

const faqs = [
  { q: '¿Cuánto cuesta asociarse?', a: 'La cuota es de 6 € al mes. Sin permanencia y sin sorpresas.' },
  { q: '¿Qué comercios pueden asociarse?', a: 'Cualquier comercio, servicio u hostelería con actividad en Narón.' },
  { q: '¿Cómo me doy de alta?', a: 'Rellenas el formulario de “Hazte socio”, te llamamos para confirmar los datos y listo.' },
  { q: '¿Cuándo empiezo a notar las ventajas?', a: 'Desde el primer mes: entras en el directorio y en la siguiente campaña conjunta.' },
];
---
<Layout title="Ventajas de asociarse | Comercio de Narón"
        description="Descubre por qué más de 90 comercios de Narón forman parte de la asociación: visibilidad, campañas conjuntas, representación y comunidad desde 6€/mes.">

  <PageHero eyebrow="Para comerciantes"
            title="Por qué asociarse merece la pena"
            subtitle="Por menos de un café a la semana, tu comercio deja de competir solo." />

  <!-- VENTAJAS GRID -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {ventajas.map((v) => (
        <div class="rounded-2xl border border-brand-100 bg-white p-7 shadow-soft">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand"><Icon name={v.icon} /></div>
          <h3 class="mt-5 text-lg font-bold">{v.title}</h3>
          <p class="mt-2 text-sm text-ink/70">{v.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- COMPARATIVA -->
  <section class="bg-cream bg-grid">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <h2 class="rule-accent text-center mx-auto w-fit font-display text-3xl font-extrabold md:text-4xl">Solo vs. asociado</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-brand-100 bg-white p-8">
          <h3 class="font-display text-xl font-bold text-ink/70">Comercio en solitario</h3>
          <ul class="mt-5 space-y-3">
            {solo.map((s) => (
              <li class="flex items-start gap-3 text-sm text-ink/70">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-100 text-red-600">✕</span> {s}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl border-2 border-brand bg-white p-8 shadow-soft">
          <h3 class="font-display text-xl font-bold text-brand">Comercio asociado</h3>
          <ul class="mt-5 space-y-3">
            {asociado.map((s) => (
              <li class="flex items-start gap-3 text-sm text-ink/80">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand"><Icon name="check" class="h-3.5 w-3.5" /></span> {s}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- QUÉ INCLUYE LA CUOTA -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-accent">La cuota incluye</p>
        <h2 class="rule-accent mt-2 font-display text-3xl font-extrabold">Todo esto, por 6&nbsp;€ al mes</h2>
        <ul class="mt-8 space-y-4">
          {incluye.map((i) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand"><Icon name="check" class="h-4 w-4" /></span>
              <span class="text-ink/80">{i}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-3xl bg-brand p-8 text-white shadow-soft md:p-10">
        <div class="font-display text-6xl font-black text-accent-soft">6€<span class="text-2xl font-bold text-white/70">/mes</span></div>
        <p class="mt-3 text-white/85">Sin permanencia. Te das de alta hoy y empiezas a aparecer en el directorio y en la próxima campaña.</p>
        <a href="/hazte-socio" class="mt-7 inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 font-bold text-brand-dark transition hover:bg-accent-soft">Quiero asociarme <Icon name="arrow" class="h-5 w-5" /></a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-cream bg-grid">
    <div class="mx-auto max-w-3xl px-4 py-20">
      <h2 class="rule-accent text-center mx-auto w-fit font-display text-3xl font-extrabold md:text-4xl">Preguntas frecuentes</h2>
      <div class="mt-10 space-y-4">
        {faqs.map((f) => (
          <details class="group rounded-2xl border border-brand-100 bg-white p-5 shadow-soft">
            <summary class="flex cursor-pointer list-none items-center justify-between font-bold text-ink">
              {f.q}
              <span class="text-brand transition group-open:rotate-45"><Icon name="sparkles" class="h-5 w-5" /></span>
            </summary>
            <p class="mt-3 text-sm text-ink/70">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA title="Súmate a los +90 comercios que ya forman parte"
       text="Te acompañamos en todo el proceso de alta. Tardas menos de un minuto."
       ctaLabel="Hazte socio" ctaHref="/hazte-socio" />
</Layout>
