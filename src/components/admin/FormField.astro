---
interface Props {
  label: string;
  name: string;
  type?: string;
  value?: string | number | null;
  placeholder?: string;
  required?: boolean;
  textarea?: boolean;
  rows?: number;
  hint?: string;
  options?: Array<{ value: string; label: string }>;
  checked?: boolean;
  pattern?: string;
  min?: string;
  max?: string;
  step?: string;
  autocomplete?: string;
}

const {
  label,
  name,
  type = 'text',
  value = '',
  placeholder,
  required = false,
  textarea = false,
  rows = 4,
  hint,
  options,
  checked,
  pattern,
  min,
  max,
  step,
  autocomplete,
} = Astro.props;

const id = `field-${name}`;
const inputClass = 'w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-[var(--color-brand)] focus:outline-none focus:ring-2 focus:ring-[var(--color-brand)]/20 placeholder:text-slate-400';
---

{type === 'checkbox' ? (
  <label class="flex items-start gap-3 rounded-lg border border-slate-200 bg-white p-3 cursor-pointer hover:bg-slate-50">
    <input type="checkbox" id={id} name={name} value="true" checked={checked} class="mt-0.5 h-4 w-4 rounded border-slate-300 text-[var(--color-brand)] focus:ring-[var(--color-brand)]" />
    <span>
      <span class="block text-sm font-medium text-slate-900">{label}</span>
      {hint && <span class="block text-xs text-slate-500 mt-0.5">{hint}</span>}
    </span>
  </label>
) : (
  <div class="space-y-1.5">
    <label for={id} class="block text-xs font-semibold uppercase tracking-wide text-slate-600">
      {label}{required && <span class="text-rose-500"> *</span>}
    </label>
    {options ? (
      <select id={id} name={name} required={required} class={inputClass}>
        <option value="">— Selecciona —</option>
        {options.map(o => <option value={o.value} selected={String(value) === o.value}>{o.label}</option>)}
      </select>
    ) : textarea ? (
      <textarea id={id} name={name} rows={rows} required={required} placeholder={placeholder} class={inputClass}>{value ?? ''}</textarea>
    ) : (
      <input
        type={type}
        id={id}
        name={name}
        value={value ?? ''}
        placeholder={placeholder}
        required={required}
        pattern={pattern}
        min={min}
        max={max}
        step={step}
        autocomplete={autocomplete}
        class={inputClass}
      />
    )}
    {hint && <p class="text-xs text-slate-500">{hint}</p>}
  </div>
)}
