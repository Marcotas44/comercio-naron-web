---
import Icon from '../Icon.astro';

interface Props {
  label: string;
  value: number | string;
  icon: string;
  tone?: 'brand' | 'accent' | 'rose' | 'sky';
  href?: string;
  sub?: string;
}

const { label, value, icon, tone = 'brand', href, sub } = Astro.props;
const palette = {
  brand:  'bg-[var(--color-brand-50)] text-[var(--color-brand-dark)]',
  accent: 'bg-amber-50 text-amber-700',
  rose:   'bg-rose-50 text-rose-700',
  sky:    'bg-sky-50 text-sky-700',
}[tone];

const Tag = href ? 'a' : 'div';
---
<Tag href={href} class="group flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-5 transition hover:shadow-md">
  <div class="flex items-center gap-3">
    <span class:list={['grid h-10 w-10 place-items-center rounded-lg', palette]}>
      <Icon name={icon} class="h-5 w-5" />
    </span>
    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">{label}</span>
  </div>
  <p class="font-display text-3xl font-semibold text-slate-900">{value}</p>
  {sub && <p class="text-xs text-slate-500">{sub}</p>}
</Tag>
