---
import Icon from '../Icon.astro';
import type { SessionUser } from '../../lib/supabase/types';

interface Props {
  title: string;
  description?: string;
  user: SessionUser;
  actions?: boolean;
}

const { title, description } = Astro.props;
---
<header class="sticky top-0 z-20 flex h-16 items-center gap-3 border-b border-slate-200 bg-white/85 px-4 backdrop-blur lg:px-8">
  <button type="button" class="rounded-md border border-slate-200 p-1.5 text-slate-600 hover:bg-slate-50 lg:hidden" data-open-sidebar aria-label="Abrir menú">
    <Icon name="menu" class="h-5 w-5" />
  </button>
  <div class="min-w-0 flex-1">
    <h1 class="truncate font-display text-xl font-semibold text-slate-900">{title}</h1>
    {description && <p class="truncate text-xs text-slate-500">{description}</p>}
  </div>
  <slot />
</header>
